{
  "database": {
    "schema": {
      "pixels_v1": {
        "id": {
          "type": "text",
          "description": "Pixel coordinate, e.g., '10:20'."
        },
        "x": {
          "type": "integer",
          "description": "The x-coordinate of the pixel."
        },
        "y": {
          "type": "integer",
          "description": "The y-coordinate of the pixel."
        },
        "color": {
          "type": "text",
          "description": "Hex color code, e.g., '#FFFFFF'."
        }
      }
    }
  }
}

